<%- include('../partials/header', { title: editing ? 'Edit Asset' : 'New Asset' }) %>
<%- include('../partials/sidebar') %>
<div class="main-content">
  <%- include('../partials/topbar', { title: editing ? 'Edit Asset' : 'New Asset' }) %>
  <div class="content-area">
    <% const page = 'assets'; %>

    <a href="/assets" class="btn btn-sm btn-outline-secondary mb-3"><i class="fas fa-arrow-left me-1"></i>Back</a>

    <div class="card">
      <div class="card-header bg-white fw-semibold">
        <i class="fas fa-<%= editing ? 'edit' : 'plus' %> me-2"></i><%= editing ? 'Edit' : 'New' %> Asset
      </div>
      <div class="card-body">
        <form method="POST" action="<%= editing ? '/assets/' + asset.id : '/assets' %>" enctype="multipart/form-data">
          <div class="row g-3">
            <% if (editing) { %>
            <div class="col-md-4">
              <label class="form-label">Asset Code</label>
              <input type="text" class="form-control" value="<%= asset.asset_code %>" disabled>
            </div>
            <% } %>
            <div class="col-md-4">
              <label class="form-label">Category <span class="text-danger">*</span></label>
              <select name="category" class="form-select" required>
                <option value="">Select...</option>
                <% ['Laptop','Desktop','Monitor','Printer','Networking','Tablet','Projector','Peripheral','Other'].forEach(c => { %>
                <option value="<%= c %>" <%= asset && asset.category === c ? 'selected' : '' %>><%= c %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Brand</label>
              <input type="text" name="brand" class="form-control" value="<%= asset ? asset.brand || '' : '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Model <span class="text-danger">*</span></label>
              <input type="text" name="model" class="form-control" value="<%= asset ? asset.model || '' : '' %>" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Serial Number</label>
              <input type="text" name="serial_number" class="form-control" value="<%= asset ? asset.serial_number || '' : '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Asset Tag</label>
              <input type="text" name="asset_tag" class="form-control" value="<%= asset ? asset.asset_tag || '' : '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Status</label>
              <select name="status" class="form-select">
                <% ['Active','In Repair','Broken','Disposed','In Storage','On Loan'].forEach(s => { %>
                <option value="<%= s %>" <%= asset && asset.status === s ? 'selected' : '' %>><%= s %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Condition</label>
              <select name="condition" class="form-select">
                <% ['Good','Fair','Poor'].forEach(c => { %>
                <option value="<%= c %>" <%= asset && asset.condition === c ? 'selected' : '' %>><%= c %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Location</label>
              <input type="text" name="location" class="form-control" value="<%= asset ? asset.location || '' : '' %>" placeholder="e.g. Room 201, IT Lab">
            </div>
            <div class="col-md-4">
              <label class="form-label">Assigned To</label>
              <input type="text" name="assigned_to" class="form-control" value="<%= asset ? asset.assigned_to || '' : '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Purchase Date</label>
              <input type="date" name="purchase_date" class="form-control" value="<%= asset ? asset.purchase_date || '' : '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Warranty Expiry</label>
              <input type="date" name="warranty_expiry" class="form-control" value="<%= asset ? asset.warranty_expiry || '' : '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Purchase Price ($)</label>
              <input type="number" step="0.01" name="purchase_price" class="form-control" value="<%= asset ? asset.purchase_price || '' : '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label">Photo</label>
              <input type="file" name="photo" class="form-control" accept="image/*">
              <% if (asset && asset.photo_path) { %>
              <small class="text-muted">Current: <%= asset.photo_path %></small>
              <% } %>
            </div>
            <div class="col-12">
              <label class="form-label">Notes</label>
              <textarea name="notes" class="form-control" rows="3"><%= asset ? asset.notes || '' : '' %></textarea>
            </div>
          </div>
          <div class="mt-4">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i><%= editing ? 'Update' : 'Create' %> Asset</button>
            <a href="/assets" class="btn btn-outline-secondary ms-2">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
