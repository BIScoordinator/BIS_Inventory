<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>QR Codes - Bulk Print</title>
  <style>
    body { font-family: 'Segoe UI', sans-serif; padding: 20px; }
    .qr-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; max-width: 800px; margin: 0 auto; }
    .qr-item { text-align: center; border: 1px dashed #ccc; padding: 15px; page-break-inside: avoid; }
    .qr-item img { width: 150px; height: 150px; }
    .qr-item .code { font-weight: bold; margin-top: 5px; }
    .qr-item .model { font-size: 12px; color: #666; }
    @media print { .no-print { display: none; } }
  </style>
</head>
<body>
  <div class="no-print" style="margin-bottom:20px;text-align:center;">
    <button onclick="window.print()" style="padding:8px 20px;font-size:16px;cursor:pointer;">Print All</button>
    <a href="/assets" style="margin-left:10px;">Back to Assets</a>
  </div>
  <div class="qr-grid">
    <% items.forEach(item => { %>
    <div class="qr-item">
      <img src="<%= item.qr %>" alt="QR">
      <div class="code"><%= item.asset.asset_code %></div>
      <div class="model"><%= item.asset.brand ? item.asset.brand + ' ' : '' %><%= item.asset.model %></div>
    </div>
    <% }); %>
  </div>
</body>
</html>
