<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - BIS Inventory</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
  <style>
    .btn-google {
      background: #fff;
      border: 1.5px solid #dadce0;
      color: #3c4043;
      font-weight: 500;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: box-shadow .2s;
    }
    .btn-google:hover {
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      background: #f8f9fa;
      color: #3c4043;
    }
    .btn-google img {
      width: 20px;
      height: 20px;
    }
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      color: #aaa;
      margin: 20px 0;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #dee2e6;
    }
  </style>
</head>
<body>
<div class="login-container">
  <div class="card login-card">
    <div class="card-body p-5">
      <div class="text-center mb-4">
        <div style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,#1a5276,#3498db);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
          <i class="fas fa-school fa-2x text-white"></i>
        </div>
        <h3 class="fw-bold" style="color:#1a5276;">BIS Inventory</h3>
        <p class="text-muted">Bali Island School - IT Asset Management</p>
      </div>

      <% if (error && error.length) { %>
        <div class="alert alert-danger py-2"><i class="fas fa-exclamation-circle me-2"></i><%= error[0] %></div>
      <% } %>

      <% if (googleEnabled) { %>
        <!-- Google Sign In -->
        <a href="/auth/google" class="btn btn-google w-100 py-2 mb-2">
          <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
          Sign in with Google
        </a>
        <p class="text-center text-muted small mb-0">Only @baliis.net accounts are allowed</p>

        <div class="divider"><span>or sign in with username</span></div>
      <% } %>

      <!-- Username / Password fallback (admin use) -->
      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label fw-semibold">Username</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-user"></i></span>
            <input type="text" name="username" class="form-control" required autofocus>
          </div>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-lock"></i></span>
            <input type="password" name="password" class="form-control" required>
          </div>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2" style="background:linear-gradient(135deg,#1a5276,#2980b9);border:none;">
          <i class="fas fa-sign-in-alt me-2"></i>Sign In
        </button>
      </form>
    </div>
  </div>
</div>
</body>
</html>
