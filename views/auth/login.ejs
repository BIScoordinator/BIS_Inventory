<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - BIS Inventory</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
</head>
<body>
<div class="login-container">
  <div class="card login-card">
    <div class="card-body p-5">
      <div class="text-center mb-4">
        <div style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,#1a5276,#3498db);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
          <i class="fas fa-school fa-2x text-white"></i>
        </div>
        <h3 class="fw-bold" style="color:#1a5276;">BIS Inventory</h3>
        <p class="text-muted">Bali Island School - IT Asset Management</p>
      </div>
      <% if (error && error.length) { %>
        <div class="alert alert-danger py-2"><i class="fas fa-exclamation-circle me-2"></i><%= error[0] %></div>
      <% } %>
      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label fw-semibold">Username</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-user"></i></span>
            <input type="text" name="username" class="form-control" required autofocus>
          </div>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Password</label>
          <div class="input-group">
            <span class="input-group-text"><i class="fas fa-lock"></i></span>
            <input type="password" name="password" class="form-control" required>
          </div>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2" style="background:linear-gradient(135deg,#1a5276,#2980b9);border:none;">
          <i class="fas fa-sign-in-alt me-2"></i>Sign In
        </button>
      </form>
    </div>
  </div>
</div>
</body>
</html>
